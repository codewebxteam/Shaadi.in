# ==============================
# Node.js Backend .gitignore
# ==============================

# Dependencies (Bohot badi size hoti hai, upload nahi karni chahiye)
node_modules/

# Environment Variables (Security risk! Isme password aur secret keys hote hain)
.env
.env.local
.env.development
.env.test
.env.production

# Logs (Faltu log files)
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# OS generated files (Mac / Windows faltu files)
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Build, coverage and temporary directories
dist/
build/
coverage/
.nyc_output/
temp/
.temp/
.cache/

# Optional REPL history
.node_repl_history